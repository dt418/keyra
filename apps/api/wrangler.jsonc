{
  "name": "keyra-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-06-13",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "keyra-db",
      "database_id": "${D1_DATABASE_ID}"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "${SESSIONS_KV_ID}"
    }
  ],
  "vars": {
    "ENVIRONMENT": "${ENVIRONMENT}"
  }
}