# Keyra API — required env vars for local dev / wrangler
# Real values live in .dev.vars (git-ignored) and in `wrangler secret put`
# Copy this file to apps/api/.dev.vars and fill in real values from 1Password.

# JWT (32 random bytes, base64 — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
JWT_SECRET=
JWT_REFRESH_SECRET=

# Cloudflare (D1 + KV)
CLOUDFLARE_ACCOUNT_ID=
D1_DATABASE_ID=
SESSIONS_KV_ID=

# OAuth
OAUTH_REDIRECT_URI=http://localhost:8788/api/v1/auth/oauth/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# Runtime
ENVIRONMENT=development
# 1 disables rate limiting in dev so e2e is fast. Always 0 in production.
DISABLE_RATE_LIMIT=1

# License key HMAC (32 random bytes — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# Signs new license keys at create time and verifies the HMAC tag on /activate and /verify.
# Local dev placeholder; production must set this via `wrangler secret put LICENSE_HMAC_SECRET`.
LICENSE_HMAC_SECRET=change-me-32-bytes-of-random

# Webhook SSRF guard — optional DNS resolution check (0 = off, 1 = on)
# When enabled, the guard resolves the webhook hostname via Cloudflare DNS and rejects answers
# in private/loopback/link-local ranges. Defends against DNS rebinding at the cost of one DNS
# round-trip per webhook create/update/test. Production recommendation: set to 1.
RESOLVE_DNS_FOR_SSRF=0

# Email verification gate (T4)
# Set to "1" to block login until users.email_verified=1. Off by default for backwards-compat
# with seeded users. Set to "0" (or leave empty/unset) to disable the gate entirely.
REQUIRE_EMAIL_VERIFICATION=0
