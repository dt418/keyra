{
  "name": "keyra",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @keyra/api test:e2e",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "dev:api": "pnpm --filter @keyra/api dev",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit"
  },
  "devDependencies": {
    "lefthook": "^2.1.9",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^22.0.0"
    }
  }
}
