# Cloudflare credentials
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# JWT Configuration
JWT_SECRET=generate-a-secure-jwt-secret
JWT_REFRESH_SECRET=generate-a-secure-refresh-secret

# OAuth Configuration (GitHub, Google, etc.)
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:5173/auth/callback
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:5173/auth/callback

# D1 Database
D1_DATABASE_ID=your-d1-database-id

# KV Namespace
SESSIONS_KV_ID=your-sessions-kv-namespace-id

# Environment
ENVIRONMENT=development
API_URL=http://localhost:8787
FRONTEND_URL=http://localhost:5173